# 复制为 .env 后填入真实值
# cp .env.example .env

# 数据库（Docker Compose 配置）
# - 本地/Codespaces: postgres://bcms:bcms_dev@localhost:5432/bcms?sslmode=disable
# - Docker 容器内: postgresql://bcms:bcms_dev@db:5432/bcms
DATABASE_URL=postgresql://bcms:bcms_dev@db:5432/bcms

# 后端端口
PORT=4000

# JWT（生产环境务必换成随机长字符串）
JWT_SECRET=change-me-in-production

# 文件存储根目录
UPLOADS_DIR=./uploads

# AI 提取 API Key（从各平台控制台获取）
QWEN_API_KEY=
DEEPSEEK_API_KEY=

# 环境标识（development / production）
ENV=development
